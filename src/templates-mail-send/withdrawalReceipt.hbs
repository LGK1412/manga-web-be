<div style="font-family: Arial, Helvetica, sans-serif; background-color:#f6f7fb; padding:24px;">
    <div
        style="max-width:680px; margin:0 auto; background:#ffffff; border-radius:10px; overflow:hidden; box-shadow:0 6px 18px rgba(0,0,0,0.06);">

        ```
        <!-- HEADER -->
        <div style="background:{{statusColor}}; padding:22px 24px;">
            <h1 style="margin:0; font-size:20px; color:#ffffff;">
                Withdrawal {{statusLabel}}
            </h1>
            <p style="margin:4px 0 0; font-size:13px; color:#e5e7eb;">
                {{PlatformName}}
            </p>
        </div>


        <!-- BODY -->
        <div style="padding:26px; font-size:14px; color:#111827; line-height:1.6;">

            <p>Hello <b>{{authorName}}</b>,</p>

            <p>
                Your withdrawal request has been
                <b style="color:{{statusColor}};">{{statusLabel}}</b>.
                {{statusMessage}}
            </p>


            <!-- TRANSACTION INFO -->
            <h3 style="margin-top:26px; font-size:15px; border-bottom:2px solid #e5e7eb; padding-bottom:6px;">
                Transaction Information
            </h3>

            <table width="100%" cellpadding="6" cellspacing="0" style="margin-top:6px;">
                <tr>
                    <td width="40%" style="color:#6b7280;">Withdrawal ID</td>
                    <td><b>{{withdrawId}}</b></td>
                </tr>

                <!-- Approved -->
                {{#if approvedAt}}
                <tr>
                    <td style="color:#6b7280;">Approved At</td>
                    <td>{{approvedAt}}</td>
                </tr>
                {{/if}}

                <!-- Paid only -->
                {{#if paidAt}}
                <tr>
                    <td style="color:#6b7280;">Paid At</td>
                    <td>{{paidAt}}</td>
                </tr>
                {{/if}}
            </table>


            <!-- PAYMENT BREAKDOWN -->
            <h3 style="margin-top:26px; font-size:15px; border-bottom:2px solid #e5e7eb; padding-bottom:6px;">
                Payment Breakdown
            </h3>

            <table width="100%" cellpadding="10" cellspacing="0" style="border-collapse:collapse; margin-top:8px;">

                <tr style="background:#f9fafb;">
                    <td>Total Points</td>
                    <td align="right">{{points}}</td>
                </tr>

                <tr>
                    <td>Gross Amount</td>
                    <td align="right">{{gross}} VND</td>
                </tr>

                <tr>
                    <td>Tax Deduction ({{taxRate}}%)</td>
                    <td align="right" style="color:#dc2626;">
                        − {{tax}} VND
                    </td>
                </tr>

                <tr style="background:#ecfeff; font-weight:bold;">
                    <td>Net Amount</td>
                    <td align="right" style="color:#0f766e;">
                        {{net}} VND
                    </td>
                </tr>
            </table>


            <!-- LEGAL -->
            {{#if legalRef}}
            <p style="margin-top:10px; font-size:12px; color:#6b7280;">
                Tax deduction is applied in accordance with <b>{{legalRef}}</b> and current Vietnamese tax regulations.
            </p>
            {{/if}}


            <!-- BANK -->
            <h3 style="margin-top:26px; font-size:15px; border-bottom:2px solid #e5e7eb; padding-bottom:6px;">
                Bank Information
            </h3>

            <table width="100%" cellpadding="6" cellspacing="0" style="margin-top:6px;">
                <tr>
                    <td width="40%" style="color:#6b7280;">Bank</td>
                    <td>{{bankCode}}</td>
                </tr>
                <tr>
                    <td style="color:#6b7280;">Account Number</td>
                    <td>•••• {{last4Digits}}</td>
                </tr>
                <tr>
                    <td style="color:#6b7280;">Account Holder</td>
                    <td>{{accountHolder}}</td>
                </tr>
            </table>


            <!-- NOTE -->
            <p style="margin-top:30px; font-size:13px; color:#6b7280;">
                This receipt is generated automatically and serves as your official transaction record.
                If you notice any discrepancy, please contact support.
            </p>

        </div>


        <!-- FOOTER -->
        <div style="background:#f3f4f6; text-align:center; padding:14px; font-size:12px; color:#6b7280;">
            © {{PlatformName}} — All rights reserved
        </div>

    </div>
    ```

</div>